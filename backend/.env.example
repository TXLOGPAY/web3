# ── App ───────────────────────────────────────────────────────────────────────
APP_NAME=TxLogPay API
DEBUG=false

# ── Stellar ───────────────────────────────────────────────────────────────────
STELLAR_NETWORK=testnet
STELLAR_HORIZON_URL=https://horizon-testnet.stellar.org
STELLAR_RPC_URL=https://soroban-testnet.stellar.org
STELLAR_FRIENDBOT_URL=https://friendbot.stellar.org

# Platform (TxLogPay) Stellar account — run setup-demo to generate
PLATFORM_SECRET_KEY=S...
PLATFORM_PUBLIC_KEY=G...

# ── Contract IDs (fill after: soroban contract deploy) ────────────────────────
FLAGS_CONTRACT_ID=
ESCROW_CONTRACT_ID=
TRADE_INFO_CONTRACT_ID=

# ── Etherfuse ─────────────────────────────────────────────────────────────────
# Get API key at: https://www.etherfuse.com
ETHERFUSE_API_KEY=your_etherfuse_api_key
ETHERFUSE_BASE_URL=https://api.etherfuse.com
ETHERFUSE_TEST_MODE=true

# ── Anthropic (for LlamaIndex RAG) ───────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://txlogpay:txlogpay@localhost:5432/txlogpay

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Platform fee (basis points) ───────────────────────────────────────────────
PLATFORM_FEE_BPS=200
